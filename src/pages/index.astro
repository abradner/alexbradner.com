---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import SectionHead from '../components/SectionHead.astro';
import ProjectCard from '../components/ProjectCard.astro';
import Icon from '../components/Icon.astro';
import { site } from '../data/site';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order).slice(0, 2);
---

<Layout title={site.name}>
  <section class="relative overflow-hidden border-b border-line">
    <div class="grid-bg pointer-events-none absolute inset-0"></div>
    <div class="wrap relative pt-14 pb-0 sm:pt-20 lg:pt-24">
      <div class="mb-6 flex items-center gap-[0.6rem]">
        <span class="h-[7px] w-[7px] rounded-full bg-accent"></span>
        <span class="font-mono text-[0.75rem] tracking-[0.14em] text-fg-muted uppercase">
          Personal Primer &mdash; Rev {site.revision}
        </span>
      </div>

      <h1 class="font-cond text-[clamp(3.2rem,9vw,6.4rem)] leading-[0.94] font-bold uppercase text-fg">
        Alex<br />Bra<em class="text-accent not-italic">d</em>ner
      </h1>

      <p class="mt-5 max-w-xl font-serif text-[clamp(1.15rem,2vw,1.45rem)] italic text-fg-muted">
        {site.tagline}
      </p>

      <p class="mt-6 max-w-2xl text-[1.02rem] text-fg">
        Ten years ago I wrote a one-page primer and never came back to it. This is the rebuild &mdash; same
        builder, considerably more mileage: startups shipped, systems shipped, a few things soldered
        together that probably shouldn't have worked.
      </p>

      <div class="mt-9 mb-14 flex flex-wrap gap-[0.9rem]">
        <a
          href="/projects"
          class="inline-flex items-center gap-2 border border-accent-fill bg-accent-fill px-[1.35rem] py-[0.85rem] font-mono text-[0.8rem] tracking-[0.08em] text-accent-ink uppercase no-underline transition-transform hover:-translate-y-[2px]"
        >
          View Projects <Icon name="arrow-right" class="h-3.5 w-3.5" />
        </a>
        <a
          href="/cv"
          class="inline-flex items-center gap-2 border border-fg px-[1.35rem] py-[0.85rem] font-mono text-[0.8rem] tracking-[0.08em] text-fg uppercase no-underline transition-[color,border-color,transform] hover:-translate-y-[2px] hover:border-accent hover:text-accent"
        >
          View CV
        </a>
      </div>
    </div>

    <div class="wrap px-0!">
      <div class="grid grid-cols-2 border-t border-line-strong sm:grid-cols-4">
        <div class="border-l-0 border-line px-5 py-3.5 sm:pl-[clamp(1.25rem,4vw,3rem)]">
          <div class="font-mono text-[0.72rem] tracking-[0.14em] text-fg-muted uppercase">Drawn</div>
          <div class="mt-1 font-mono text-[0.85rem] text-fg">A. Bradner</div>
        </div>
        <div class="border-l border-line px-5 py-3.5">
          <div class="font-mono text-[0.72rem] tracking-[0.14em] text-fg-muted uppercase">Scale</div>
          <div class="mt-1 font-mono text-[0.85rem] text-fg">Full Stack</div>
        </div>
        <div class="border-l-0 border-line px-5 py-3.5 sm:border-l">
          <div class="font-mono text-[0.72rem] tracking-[0.14em] text-fg-muted uppercase">Status</div>
          <div class="mt-1 font-mono text-[0.85rem] text-accent">Actively Building</div>
        </div>
        <div class="border-l border-line px-5 py-3.5">
          <div class="font-mono text-[0.72rem] tracking-[0.14em] text-fg-muted uppercase">Rev</div>
          <div class="mt-1 font-mono text-[0.85rem] text-fg">{site.revision}</div>
        </div>
      </div>
    </div>
  </section>

  <section class="reveal border-b border-line py-14 sm:py-16">
    <div class="wrap">
      <SectionHead num="00" title="Parameters" />
      <div class="grid grid-cols-1 border-t border-l border-line-strong sm:grid-cols-2 lg:grid-cols-4">
        <div class="border-r border-b border-line-strong p-6">
          <div class="font-mono text-[0.72rem] tracking-[0.14em] text-fg-muted uppercase">Core Stack</div>
          <div class="mt-[0.65rem] font-mono text-[0.98rem] leading-[1.55] text-fg">
            Ruby / Rails <b class="font-semibold text-accent">[9]</b><br />
            TypeScript <b class="font-semibold text-accent">[9]</b><br />
            Ember &middot; React <b class="font-semibold text-accent">[8]</b>
          </div>
        </div>
        <div class="border-r border-b border-line-strong p-6">
          <div class="font-mono text-[0.72rem] tracking-[0.14em] text-fg-muted uppercase">Also Fluent In</div>
          <div class="mt-[0.65rem] font-mono text-[0.98rem] leading-[1.55] text-fg">
            Haskell <b class="font-semibold text-accent">[7]</b><br />
            Python <b class="font-semibold text-accent">[6]</b><br />
            C / C++ / Java <b class="font-semibold text-accent">[6&ndash;7]</b>
          </div>
        </div>
        <div class="border-r border-b border-line-strong p-6">
          <div class="font-mono text-[0.72rem] tracking-[0.14em] text-fg-muted uppercase">Education</div>
          <div class="mt-[0.65rem] font-mono text-[0.98rem] leading-[1.55] text-fg">
            BSc Computer Science<br />Univ. of New South Wales
          </div>
        </div>
        <div class="border-r border-b border-line-strong p-6">
          <div class="font-mono text-[0.72rem] tracking-[0.14em] text-fg-muted uppercase">Languages Spoken</div>
          <div class="mt-[0.65rem] font-mono text-[0.98rem] leading-[1.55] text-fg">
            English<br />中文 &middot; Mandarin (HSK 4)<br />Espa&ntilde;ol
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="reveal border-b border-line py-14 sm:py-16">
    <div class="wrap">
      <SectionHead num="01" title="Philosophy" />
      <div class="grid grid-cols-[3.5rem_1fr] gap-4 sm:grid-cols-[5rem_1fr]">
        <div class="font-cond text-[3.4rem] leading-none text-teal">&ldquo;</div>
        <div>
          <blockquote class="max-w-2xl font-serif text-[clamp(1.2rem,2.4vw,1.55rem)] leading-[1.5] text-fg italic">
            Figure out what the problem is before you start building solutions. Validate before you build,
            validate once you've built &mdash; then analyse the gap. I call this hypothesis-driven
            development.
          </blockquote>
          <cite class="mt-4 block font-mono text-[0.75rem] tracking-[0.08em] text-fg-muted not-italic">
            &mdash; On Business, from <a href="/about" class="underline hover:text-accent">About</a>
          </cite>
        </div>
      </div>
    </div>
  </section>

  <section class="reveal py-14 sm:py-16">
    <div class="wrap">
      <SectionHead num="02" title="Selected Work" />
      <div class="grid grid-cols-1 gap-[1.4rem] sm:grid-cols-2">
        {projects.map((project) => <ProjectCard project={project} />)}
      </div>
      <div class="mt-6 flex justify-end">
        <a
          href="/projects"
          class="border-b border-line-strong pb-[2px] font-mono text-[0.8rem] tracking-[0.06em] text-fg no-underline hover:border-accent hover:text-accent"
        >
          All projects (5) &rarr;
        </a>
      </div>
    </div>
  </section>
</Layout>
