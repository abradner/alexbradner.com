---
import Layout from '../layouts/Layout.astro';
import SectionHead from '../components/SectionHead.astro';
import { skills, skillScale, education, hobbies, languages, social } from '../data/site';

const linkedin = social.find((s) => s.key === 'LI')!;

const langGroups = [
  { label: 'Core Stack', items: skills.languages.topLevel },
  { label: 'Markup', items: skills.languages.markup },
  { label: 'Currently Learning', items: skills.languages.learning },
  { label: 'Known, Not Recent', items: skills.languages.dormant },
];
---

<Layout title="CV" description="Alex Bradner's skills matrix, education and background.">
  <section class="reveal border-b border-line py-14 sm:py-20">
    <div class="wrap">
      <div class="mb-3 font-mono text-[0.75rem] tracking-[0.14em] text-accent uppercase">§03 &mdash; CV</div>
      <h1 class="font-cond text-[clamp(2.4rem,6vw,4rem)] leading-[0.96] font-bold uppercase text-fg">Hire me</h1>
      <p class="mt-4 max-w-xl text-[1rem] text-fg-muted">
        The skills matrix below is self-rated on a 1&ndash;10 scale &mdash; see the legend at the bottom for
        what each number actually means. For the fuller story, the
        <a href={linkedin.href} target="_blank" rel="noopener noreferrer" class="text-accent underline underline-offset-2">LinkedIn profile</a>
        and <a href="/projects" class="text-accent underline underline-offset-2">Projects</a> section round it out.
      </p>
    </div>
  </section>

  <section class="reveal border-b border-line py-14 sm:py-16">
    <div class="wrap">
      <SectionHead num="03.1" title="Languages & Frameworks" />
      <div class="grid grid-cols-1 border-t border-l border-line-strong sm:grid-cols-2 lg:grid-cols-4">
        {
          langGroups.map((group) => (
            <div class="border-r border-b border-line-strong p-6">
              <div class="font-mono text-[0.72rem] tracking-[0.14em] text-fg-muted uppercase">{group.label}</div>
              <div class="mt-[0.65rem] space-y-1.5 font-mono text-[0.92rem] leading-relaxed text-fg">
                {group.items.map((lang) => (
                  <div>
                    {lang.name} <b class="font-semibold text-accent">[{lang.level}]</b>
                    {'children' in lang && lang.children && (
                      <div class="pl-3 text-fg-muted">
                        {lang.children.map((child) => (
                          <div>
                            {child.name} <b class="font-semibold text-accent">[{child.level}]</b>
                          </div>
                        ))}
                      </div>
                    )}
                  </div>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="reveal border-b border-line py-14 sm:py-16">
    <div class="wrap">
      <SectionHead num="03.2" title="Tools & Practice" />
      <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-4">
        <div>
          <h3 class="font-cond text-lg font-bold uppercase text-fg">Tools</h3>
          <div class="mt-3 flex flex-wrap gap-[0.4rem]">
            {skills.development.tools.map((t) => (
              <span class="border border-line-strong px-[0.55rem] py-[0.28rem] font-mono text-[0.68rem] tracking-[0.03em] text-fg-muted uppercase">{t}</span>
            ))}
          </div>
        </div>
        <div>
          <h3 class="font-cond text-lg font-bold uppercase text-fg">Soft Skills</h3>
          <div class="mt-3 flex flex-wrap gap-[0.4rem]">
            {skills.development.soft.map((t) => (
              <span class="border border-line-strong px-[0.55rem] py-[0.28rem] font-mono text-[0.68rem] tracking-[0.03em] text-fg-muted uppercase">{t}</span>
            ))}
          </div>
        </div>
        <div>
          <h3 class="font-cond text-lg font-bold uppercase text-fg">Startups &amp; Business</h3>
          <div class="mt-3 flex flex-wrap gap-[0.4rem]">
            {skills.business.map((t) => (
              <span class="border border-line-strong px-[0.55rem] py-[0.28rem] font-mono text-[0.68rem] tracking-[0.03em] text-fg-muted uppercase">{t}</span>
            ))}
          </div>
        </div>
        <div>
          <h3 class="font-cond text-lg font-bold uppercase text-fg">Misc</h3>
          <div class="mt-3 flex flex-wrap gap-[0.4rem]">
            {[...skills.misc.general, ...skills.misc.adobe].map((t) => (
              <span class="border border-line-strong px-[0.55rem] py-[0.28rem] font-mono text-[0.68rem] tracking-[0.03em] text-fg-muted uppercase">{t}</span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="reveal border-b border-line py-14 sm:py-16">
    <div class="wrap grid grid-cols-1 gap-10 lg:grid-cols-2">
      <div>
        <SectionHead num="03.3" title="Education" />
        <ul class="space-y-4">
          {
            education.map((e) => (
              <li class="border-l-2 border-line-strong pl-4">
                <div class="font-cond text-lg font-bold text-fg">{e.qualification}</div>
                <div class="font-mono text-[0.85rem] text-fg-muted">{e.institution}</div>
              </li>
            ))
          }
        </ul>
      </div>
      <div>
        <SectionHead num="03.4" title="Personal" />
        <div class="grid grid-cols-2 gap-6">
          <div>
            <div class="font-mono text-[0.72rem] tracking-[0.14em] text-fg-muted uppercase">Hobbies</div>
            <ul class="mt-2 space-y-1.5 text-[0.92rem] text-fg">
              {hobbies.map((h) => <li>{h}</li>)}
            </ul>
          </div>
          <div>
            <div class="font-mono text-[0.72rem] tracking-[0.14em] text-fg-muted uppercase">Languages</div>
            <ul class="mt-2 space-y-1.5 text-[0.92rem] text-fg">
              {languages.map((l) => <li>{l}</li>)}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="reveal py-14 sm:py-16">
    <div class="wrap">
      <SectionHead num="03.5" title="Skill Scale Legend" />
      <ol class="grid grid-cols-1 gap-x-8 gap-y-2 font-mono text-[0.82rem] leading-relaxed text-fg-muted sm:grid-cols-2">
        {
          skillScale.map(([n, desc]) => (
            <li>
              <b class="font-semibold text-accent">[{n}]</b> {desc}
            </li>
          ))
        }
      </ol>
    </div>
  </section>
</Layout>
