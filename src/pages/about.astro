---
import Layout from '../layouts/Layout.astro';
import SectionHead from '../components/SectionHead.astro';
import { philosophies, outsideOfWork } from '../data/site';
---

<Layout title="About" description="How Alex Bradner thinks and what he likes — philosophies on software, business and life.">
  <section class="reveal border-b border-line py-14 sm:py-20">
    <div class="wrap">
      <div class="mb-3 font-mono text-[0.75rem] tracking-[0.14em] text-accent uppercase">§01 &mdash; About</div>
      <h1 class="font-cond text-[clamp(2.4rem,6vw,4rem)] leading-[0.96] font-bold uppercase text-fg">
        How I think, <br />what I like
      </h1>
    </div>
  </section>

  <section class="reveal border-b border-line py-14 sm:py-16">
    <div class="wrap">
      <SectionHead num="01.1" title="Philosophies" />
      <div class="grid grid-cols-1 gap-10 sm:grid-cols-3">
        {
          philosophies.map((group) => (
            <div>
              <h3 class="font-cond text-xl font-bold uppercase text-fg">{group.title}</h3>
              <ul class="mt-3 space-y-3">
                {group.points.map((p) => (
                  <li class="border-l-2 border-line-strong pl-4 text-[0.98rem] leading-relaxed text-fg">{p}</li>
                ))}
              </ul>
              {group.long && (
                <div class="mt-4 border-l-2 border-teal pl-4">
                  <p class="text-[0.94rem] leading-relaxed text-fg">{group.long.intro}</p>
                  <ol class="mt-3 space-y-1.5 font-mono text-[0.82rem] leading-relaxed text-fg-muted">
                    {group.long.steps.map((step, i) => (
                      <li>
                        <span class="text-teal">{String(i + 1).padStart(2, '0')}.</span> {step}
                      </li>
                    ))}
                  </ol>
                  <p class="mt-3 text-[0.86rem] leading-relaxed text-fg-muted italic">{group.long.outro}</p>
                </div>
              )}
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="reveal py-14 sm:py-16">
    <div class="wrap">
      <SectionHead num="01.2" title="Outside of Work" />
      <ul class="grid grid-cols-1 gap-x-8 gap-y-3 sm:grid-cols-2">
        {
          outsideOfWork.map((line) => (
            <li class="flex items-start gap-3 text-[0.98rem] leading-relaxed text-fg">
              <span class="mt-2 h-1.5 w-1.5 shrink-0 bg-accent" />
              {line}
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</Layout>
