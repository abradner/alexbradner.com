---
interface Props {
  num: string;
  title: string;
}

const { num, title } = Astro.props;
---

<div class="mb-9 flex items-baseline gap-4">
  <span class="font-mono text-[0.85rem] text-accent">§{num}</span>
  <h2 class="font-cond text-[clamp(1.7rem,3.4vw,2.3rem)] font-bold uppercase text-fg">{title}</h2>
  <span class="ml-2 h-px flex-1 bg-line-strong"></span>
</div>
