---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { pid, title, tagline, summary, period, image, tech, skills } = project.data;
const chips = (tech.length ? tech : skills).slice(0, 4);
---

<article class="reveal group relative border border-line-strong bg-bg-raised p-6 transition-[border-color,transform] duration-200 hover:-translate-y-[3px] hover:border-accent sm:p-7">
  <span class="pointer-events-none absolute -top-px -left-px h-2.5 w-2.5 border-t-[1.5px] border-l-[1.5px] border-fg-muted transition-colors group-hover:border-accent"></span>
  <span class="pointer-events-none absolute -bottom-px -right-px h-2.5 w-2.5 border-r-[1.5px] border-b-[1.5px] border-fg-muted transition-colors group-hover:border-accent"></span>

  <a href={`/projects/${project.id}`} class="absolute inset-0" aria-label={`View ${title}`}></a>

  <div class="flex items-start gap-4">
    {
      image && (
        <Image
          src={image}
          alt={`${title} logo`}
          width={48}
          height={48}
          class="h-12 w-12 shrink-0 border border-line-strong object-cover"
        />
      )
    }
    <div class="min-w-0">
      <div class="font-mono text-[0.74rem] tracking-[0.1em] text-accent">
        {pid}{period && <span class="text-fg-muted"> / {period}</span>}
      </div>
      <h3 class="mt-1 font-cond text-2xl font-bold uppercase text-fg">{title}</h3>
    </div>
  </div>

  <p class="mt-3 font-serif text-[0.95rem] italic text-fg-muted">{tagline}</p>
  <p class="mt-2 text-[0.94rem] text-fg">{summary}</p>

  <div class="mt-4 flex flex-wrap gap-[0.4rem]">
    {
      chips.map((c) => (
        <span class="border border-line-strong px-[0.55rem] py-[0.28rem] font-mono text-[0.68rem] tracking-[0.03em] text-fg-muted uppercase">
          {c}
        </span>
      ))
    }
  </div>
</article>
